            "indexByName": {
              "user": 0,
              "device_type": 1,
              "title": 2,
              "child_title": 3,
              "grandchild_index": 4,
              "library": 6,
              "stream_type": 7,
              "stream_resolution": 8,
              "stream_file_resolution": 9,
              "transcode_type": 10,
              "subtitle_action": 11,
              "location": 12,
              "local": 13,
              "Value": 14
            },
            "renameByName": {
              "library": "Library",
              "title": "Title",
              "child_title": "Season",
              "grandchild_index": "Episode",
              "user": "User",
              "device_type": "Client",
              "stream_type": "Stream",
              "stream_resolution": "Resolution",
              "stream_file_resolution": "File Resolution",
              "transcode_type": "Transcode",
              "subtitle_action": "Subtitles",
              "location": "Location",
              "local": "Local",
              "Value": "Play Time"
            }
          }
        }
      ]
