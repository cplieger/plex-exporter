    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Play Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 20,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Play Time",
            "desc": true
          }
        ]
      },
      "title": "Active Sessions",
      "type": "table",
      "targets": [
        {
          "expr": "plex_play_seconds_total{server=~\"$server\"}",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "server": true,
              "server_id": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "library_id": true,
              "library_type": true,
              "media_type": true,
              "session": true,
              "device": true,
              "hostname": true,
              "__tenant_id__": true,
              "grandchild_title": true
