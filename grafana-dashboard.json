          ],
          "countRows": false,
          "fields": [
            "Items",
            "Storage",
            "Duration"
          ]
        }
      },
      "title": "",
      "type": "table",
      "targets": [
        {
          "expr": "sum by (library) (plex_library_items{server=~\"$server\"})",
          "legendFormat": "",
