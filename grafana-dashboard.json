        },
        {
          "expr": "sum by (library) (plex_library_storage_bytes{server=~\"$server\"})",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum by (library) (plex_library_duration_milliseconds{server=~\"$server\"})",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "library",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time #A": true,
              "Time #B": true,
              "Time #C": true
            },
            "indexByName": {
              "library": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3
            },
            "renameByName": {
              "library": "Library",
              "Value #A": "Items",
              "Value #B": "Storage",
              "Value #C": "Duration"
            }
          }
        }
      ]
